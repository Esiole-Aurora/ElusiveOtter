<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>WinExe</OutputType>
        <TargetFramework>net9.0-windows</TargetFramework>
        <Nullable>enable</Nullable>
        <UseWindowsForms>true</UseWindowsForms>
        <ImplicitUsings>enable</ImplicitUsings>
    </PropertyGroup>

    <ItemGroup>
      <Compile Update="DeckSelectorScreen.cs">
        <SubType>UserControl</SubType>
      </Compile>
      <Compile Update="StatsCalcScreen.cs">
        <SubType>UserControl</SubType>
      </Compile>
      <Compile Update="RandomCard.cs">
        <SubType>UserControl</SubType>
      </Compile>
      <Compile Update="ModifyDecksList.cs">
        <SubType>UserControl</SubType>
      </Compile>
      <Compile Update="RulingsScreen.cs">
        <SubType>UserControl</SubType>
      </Compile>
    </ItemGroup>

    <ItemGroup>
      <None Update="DecksList.csv">
        <CopyToOutputDirectory>Always</CopyToOutputDirectory>
      </None>
    </ItemGroup>

</Project>